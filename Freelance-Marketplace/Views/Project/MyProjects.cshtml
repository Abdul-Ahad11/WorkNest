@model IEnumerable<FreelanceMarketplace.Models.Project>

<div class="container mt-4">
    <h2>My Projects</h2>
    <a asp-action="Create" class="btn btn-primary mb-3">Post New Project</a>

    <table class="table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Budget</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Budget</td>
                    <td>@item.Status</td>
                </tr>
            }
        </tbody>
    </table>
</div>
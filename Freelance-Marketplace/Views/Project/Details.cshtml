@model FreelanceMarketplace.ViewModels.Project.ProjectDetailsViewModel
@{
    ViewData["Title"] = Model.Project.Title;
    var project = Model.Project;
}

<div class="container mt-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Project" asp-action="Browse">Browse</a></li>
            <li class="breadcrumb-item active">@project.Title</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white d-flex justify-content-between align-items-center border-bottom">
                    <div>
                        <h3 class="fw-bold mb-1">@project.Title</h3>
                        <span class="badge bg-primary me-1">@project.Category?.Name</span>
                        @if (project.Status == FreelanceMarketplace.Models.ProjectStatus.Open)
                        {
                            <span class="badge bg-success">Open for Bids</span>
                        }
                        else if (project.Status == FreelanceMarketplace.Models.ProjectStatus.InProgress)
                        {
                            <span class="badge bg-warning text-dark">In Progress</span>
                        }
                        else if (project.Status == FreelanceMarketplace.Models.ProjectStatus.Completed)
                        {
                            <span class="badge bg-info">Completed</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Cancelled</span>
                        }
                    </div>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <h6 class="fw-bold text-muted">Posted by</h6>
                        <p class="mb-0">@project.Client?.FullName</p>
                        <small class="text-muted">Member since @(project.Client?.CreatedAt.ToString("MMM yyyy") ?? "N/A")</small>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(project.RequiredSkills))
                    {
                        <div class="mb-4">
                            <h6 class="fw-bold text-muted">Required Skills</h6>
                            <div>
                                @foreach (var skill in project.RequiredSkills.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                                {
                                    <span class="badge bg-light text-dark border me-1 mb-1">@skill</span>
                                }
                            </div>
                        </div>
                    }

                    <div class="mb-4">
                        <h6 class="fw-bold text-muted">Description</h6>
                        <p class="text-dark" style="white-space: pre-wrap; line-height: 1.8;">@project.Description</p>
                    </div>

                    @if (!string.IsNullOrEmpty(project.AttachmentPath))
                    {
                        <div class="mb-4">
                            <a href="@project.AttachmentPath" class="btn btn-outline-primary" target="_blank">
                                <i class="bi bi-paperclip me-2"></i>Download Attachment
                            </a>
                        </div>
                    }
                </div>
            </div>

            @if (Model.IsClient && project.Bids.Any() && project.Status == FreelanceMarketplace.Models.ProjectStatus.Open)
            {
                <div class="card shadow-sm border-0 mt-4">
                    <div class="card-header bg-white border-bottom">
                        <h5 class="fw-bold mb-0"><i class="bi bi-chat-dots me-2"></i>Received Bids (@Model.Bids.Count)</h5>
                    </div>
                    <div class="card-body">
                        @foreach (var bid in Model.Bids.OrderBy(b => b.Amount))
                        {
                            <div class="border rounded p-3 mb-3 @(bid.Status == FreelanceMarketplace.Models.BidStatus.Accepted ? "border-success bg-success bg-opacity-10" : "")">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h6 class="fw-bold mb-1">@bid.Freelancer?.FullName</h6>
                                        <p class="text-muted small mb-1">@bid.ProposalMessage</p>
                                        <small class="text-muted">
                                            <i class="bi bi-clock me-1"></i>@bid.DeliveryDays days delivery
                                        </small>
                                    </div>
                                    <div class="text-end">
                                        <div class="fw-bold text-success fs-5">$@bid.Amount.ToString("N0")</div>
                                        @if (bid.Status == FreelanceMarketplace.Models.BidStatus.Pending)
                                        {
                                            <button class="btn btn-success btn-sm mt-2 award-btn" data-bid-id="@bid.Id" data-freelancer="@bid.Freelancer?.FullName">
                                                <i class="bi bi-award me-1"></i>Award
                                            </button>
                                        }
                                        else if (bid.Status == FreelanceMarketplace.Models.BidStatus.Accepted)
                                        {
                                            <span class="badge bg-success mt-2 d-block">Accepted</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary mt-2 d-block">Rejected</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">Project Details</h5>
                    <table class="table table-borderless mb-0">
                        <tr>
                            <td class="text-muted ps-0"><i class="bi bi-currency-dollar me-2"></i>Budget</td>
                            <td class="fw-bold text-end">
                                @if (project.MaxBudget.HasValue)
                                {
                                    <span>$@project.Budget.ToString("N0") - $@project.MaxBudget?.ToString("N0")</span>
                                }
                                else
                                {
                                    <span>$@project.Budget.ToString("N0")</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted ps-0"><i class="bi bi-calendar me-2"></i>Deadline</td>
                            <td class="fw-bold text-end">@project.Deadline.ToString("MMM dd, yyyy")</td>
                        </tr>
                        <tr>
                            <td class="text-muted ps-0"><i class="bi bi-clock me-2"></i>Time Left</td>
                            <td class="fw-bold text-end">
                                @if (project.Deadline > DateTime.Now)
                                {
                                    <span class="text-success">@((project.Deadline - DateTime.Now).Days) days</span>
                                }
                                else
                                {
                                    <span class="text-danger">Expired</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted ps-0"><i class="bi bi-chat me-2"></i>Bids</td>
                            <td class="fw-bold text-end">@project.Bids.Count</td>
                        </tr>
                        <tr>
                            <td class="text-muted ps-0"><i class="bi bi-eye me-2"></i>Views</td>
                            <td class="fw-bold text-end">@project.ViewCount</td>
                        </tr>
                        <tr>
                            <td class="text-muted ps-0"><i class="bi bi-calendar-plus me-2"></i>Posted</td>
                            <td class="fw-bold text-end">@project.CreatedAt.ToString("MMM dd, yyyy")</td>
                        </tr>
                    </table>
                </div>
            </div>

            @if (Model.IsClient)
            {
                <div class="card shadow-sm border-0 mb-3">
                    <div class="card-body">
                        <h5 class="fw-bold mb-3">Actions</h5>
                        @if (project.Status == FreelanceMarketplace.Models.ProjectStatus.Open)
                        {
                            <a asp-controller="Project" asp-action="Edit" asp-route-id="@project.Id" class="btn btn-outline-primary w-100 mb-2">
                                <i class="bi bi-pencil me-2"></i>Edit Project
                            </a>
                            <form asp-controller="Project" asp-action="Cancel" asp-route-id="@project.Id" method="post" onsubmit="return confirm('Are you sure you want to cancel this project?');">
                                <input type="hidden" name="__RequestVerificationToken" value="@System.Text.Encodings.Web.HtmlEncoder.Default.Encode(System.Security.Claims.ClaimsPrincipal.Current?.Identities.FirstOrDefault()?.FindFirst("__RequestVerificationToken")?.Value ?? "")" />
                                <button type="submit" class="btn btn-outline-danger w-100">
                                    <i class="bi bi-x-circle me-2"></i>Cancel Project
                                </button>
                            </form>
                        }
                        @if (project.Status == FreelanceMarketplace.Models.ProjectStatus.InProgress)
                        {
                            <form asp-controller="Project" asp-action="MarkCompleted" asp-route-id="@project.Id" method="post" onsubmit="return confirm('Mark this project as completed?');">
                                <input type="hidden" name="__RequestVerificationToken" value="@System.Text.Encodings.Web.HtmlEncoder.Default.Encode(System.Security.Claims.ClaimsPrincipal.Current?.Identities.FirstOrDefault()?.FindFirst("__RequestVerificationToken")?.Value ?? "")" />
                                <button type="submit" class="btn btn-success w-100">
                                    <i class="bi bi-check-circle me-2"></i>Mark Completed
                                </button>
                            </form>
                        }
                    </div>
                </div>
            }

            @if (Model.IsFreelancer && project.Status == FreelanceMarketplace.Models.ProjectStatus.Open)
            {
                <div class="card shadow-sm border-0 mb-3">
                    <div class="card-body">
                        <h5 class="fw-bold mb-3">Submit Your Bid</h5>

                        @if (Model.HasAlreadyBid)
                        {
                            <div class="alert alert-info">
                                <i class="bi bi-info-circle me-2"></i>You have already submitted a bid for this project.
                            </div>
                            @if (Model.CurrentUserBid != null)
                            {
                                <div class="border rounded p-3 mb-3">
                                    <div class="fw-bold text-success fs-5">$@Model.CurrentUserBid.Amount.ToString("N0")</div>
                                    <p class="text-muted small mb-1">@Model.CurrentUserBid.ProposalMessage</p>
                                    <small class="text-muted">@Model.CurrentUserBid.DeliveryDays days delivery</small>
                                    <div class="mt-2">
                                        @if (Model.CurrentUserBid.Status == FreelanceMarketplace.Models.BidStatus.Pending)
                                        {
                                            <span class="badge bg-warning text-dark">Pending</span>
                                            <form asp-controller="Bid" asp-action="WithdrawBid" method="post" class="d-inline">
                                                <input type="hidden" name="bidId" value="@Model.CurrentUserBid.Id" />
                                                <input type="hidden" name="__RequestVerificationToken" value="@System.Text.Encodings.Web.HtmlEncoder.Default.Encode(System.Security.Claims.ClaimsPrincipal.Current?.Identities.FirstOrDefault()?.FindFirst("__RequestVerificationToken")?.Value ?? "")" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger ms-2">Withdraw</button>
                                            </form>
                                        }
                                        else if (Model.CurrentUserBid.Status == FreelanceMarketplace.Models.BidStatus.Accepted)
                                        {
                                            <span class="badge bg-success">Accepted</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Rejected</span>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <form id="bidForm">
                                <input type="hidden" id="projectId" value="@project.Id" />
                                <input type="hidden" name="__RequestVerificationToken" value="@System.Text.Encodings.Web.HtmlEncoder.Default.Encode(System.Security.Claims.ClaimsPrincipal.Current?.Identities.FirstOrDefault()?.FindFirst("__RequestVerificationToken")?.Value ?? "")" />

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Your Bid Amount ($)</label>
                                    <div class="input-group">
                                        <span class="input-group-text">$</span>
                                        <input type="number" id="bidAmount" class="form-control" placeholder="500" step="0.01" min="1" />
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Proposal Message</label>
                                    <textarea id="bidProposal" class="form-control" rows="4" placeholder="Describe why you are the best fit for this project..."></textarea>
                                    <div class="form-text">Minimum 20 characters</div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Delivery Days</label>
                                    <input type="number" id="bidDeliveryDays" class="form-control" placeholder="30" min="1" max="365" />
                                </div>

                                <div id="bidErrorMsg" style="display:none;"></div>

                                <button type="submit" id="bidSubmitBtn" class="btn btn-primary w-100 fw-bold">
                                    <i class="bi bi-send me-2"></i>Submit Bid
                                </button>
                            </form>

                            <div id="bidSuccessMsg" style="display:none;"></div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/bid-submit.js"></script>
}
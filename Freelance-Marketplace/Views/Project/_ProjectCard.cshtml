@model FreelanceMarketplace.Models.Project

<div class="col-lg-4 col-md-6 mb-4">
    <div class="card h-100 shadow-sm border-0 project-card">
        <div class="card-header bg-white d-flex justify-content-between align-items-center border-bottom">
            <span class="badge bg-primary">@(Model.Category?.Name ?? "Uncategorized")</span>
            @if (Model.Status == FreelanceMarketplace.Models.ProjectStatus.Open)
            {
                <span class="badge bg-success">Open</span>
            }
            else if (Model.Status == FreelanceMarketplace.Models.ProjectStatus.InProgress)
            {
                <span class="badge bg-warning text-dark">In Progress</span>
            }
            else if (Model.Status == FreelanceMarketplace.Models.ProjectStatus.Completed)
            {
                <span class="badge bg-info">Completed</span>
            }
            else
            {
                <span class="badge bg-secondary">@Model.Status</span>
            }
        </div>
        <div class="card-body d-flex flex-column">
            <h5 class="card-title fw-bold text-truncate" title="@Model.Title">@Model.Title</h5>
            <p class="card-text text-muted small flex-grow-1">
                @(Model.Description.Length > 120 ? Model.Description[..120] + "..." : Model.Description)
            </p>
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="fw-bold text-success">
                    @if (Model.MaxBudget.HasValue)
                    {
                        <span>$@Model.Budget.ToString("N0") - $@Model.MaxBudget?.ToString("N0")</span>
                    }
                    else
                    {
                        <span>$@Model.Budget.ToString("N0")</span>
                    }
                </div>
                <div class="text-muted small">
                    <i class="bi bi-clock me-1"></i>
                    @if (Model.Deadline > DateTime.Now)
                    {
                        <span>@((Model.Deadline - DateTime.Now).Days) days left</span>
                    }
                    else
                    {
                        <span class="text-danger">Expired</span>
                    }
                </div>
            </div>
            <div class="d-flex justify-content-between text-muted small">
                <span><i class="bi bi-person me-1"></i>@(Model.Client?.FullName ?? "Unknown")</span>
                <span><i class="bi bi-chat me-1"></i>@(Model.Bids?.Count ?? 0) bids</span>
            </div>
            <a asp-controller="Project" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm w-100 mt-3 fw-bold">View Details</a>
        </div>
    </div>
</div>
@model FreelanceMarketplace.ViewModels.Project.ProjectEditViewModel
@{
    ViewData["Title"] = "Edit Project";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
            <h3 class="fw-bold text-primary"><i class="bi bi-pencil-square me-2"></i>Edit Project</h3>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-bold"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-bold"></label>
                    <textarea asp-for="Description" class="form-control" rows="6"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="Budget" class="form-label fw-bold"></label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="Budget" class="form-control" type="number" step="0.01" />
                        </div>
                        <span asp-validation-for="Budget" class="text-danger"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="MaxBudget" class="form-label fw-bold">Max Budget (optional)</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="MaxBudget" class="form-control" type="number" step="0.01" />
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Deadline" class="form-label fw-bold"></label>
                        <input asp-for="Deadline" class="form-control" type="date" />
                        <span asp-validation-for="Deadline" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="CategoryId" class="form-label fw-bold">Category</label>
                    <select asp-for="CategoryId" asp-items="Model.CategoryList" class="form-select">
                        <option value="">-- Select a Category --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="RequiredSkills" class="form-label fw-bold">Required Skills (comma separated)</label>
                    <input asp-for="RequiredSkills" class="form-control" placeholder="e.g., C#, ASP.NET, SQL" />
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary px-4 fw-bold">
                        <i class="bi bi-check-lg me-2"></i>Save Changes
                    </button>
                    <a asp-controller="Project" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary ms-2">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
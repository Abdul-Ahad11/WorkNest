@{
    ViewData["Title"] = "Access Denied";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="display-1 text-danger fw-bold mb-3">403</div>
            <h1 class="text-danger fw-bold mb-3"><i class="bi bi-shield-exclamation me-2"></i>Access Denied</h1>
            <p class="text-muted lead mb-4">
                You do not have permission to access this page.
                Please contact an administrator if you believe this is an error.
            </p>
            <div class="mt-4">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg px-5">
                    <i class="bi bi-house-door me-2"></i>Go Home
                </a>
            </div>
        </div>
    </div>
</div>
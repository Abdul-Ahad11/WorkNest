@{
    ViewData["Title"] = "WorkNest - Find Expert Freelancers";
}

<div class="hero-section text-white py-5 mb-5 rounded shadow-sm mt-3 text-center" style="background: linear-gradient(135deg, #0d6efd 0%, #6610f2 100%);">
    <div class="container py-5">
        <h1 class="display-4 fw-bold mb-3">Find Expert Freelancers for Your Projects</h1>
        <p class="lead mb-4 fs-4 opacity-90">Connect with top talent from around the world. Post projects, receive competitive bids, and get work done.</p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg text-primary fw-bold px-5 shadow-sm">
                <i class="bi bi-plus-circle me-2"></i>Post a Project
            </a>
            <a asp-controller="Project" asp-action="Browse" class="btn btn-outline-light btn-lg px-5 shadow-sm">
                <i class="bi bi-search me-2"></i>Browse Projects
            </a>
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="row g-3">
        <div class="col-md-3 col-6">
            <div class="card border-0 shadow-sm py-3 text-center h-100" style="border-left: 4px solid #0d6efd !important;">
                <div class="card-body">
                    <h2 class="text-primary fw-bold display-5 mb-0">@ViewBag.TotalProjects</h2>
                    <p class="text-muted mb-0">Total Projects</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card border-0 shadow-sm py-3 text-center h-100" style="border-left: 4px solid #198754 !important;">
                <div class="card-body">
                    <h2 class="text-success fw-bold display-5 mb-0">@ViewBag.TotalFreelancers</h2>
                    <p class="text-muted mb-0">Freelancers</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card border-0 shadow-sm py-3 text-center h-100" style="border-left: 4px solid #ffc107 !important;">
                <div class="card-body">
                    <h2 class="text-warning fw-bold display-5 mb-0">@ViewBag.CompletedProjects</h2>
                    <p class="text-muted mb-0">Completed</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card border-0 shadow-sm py-3 text-center h-100" style="border-left: 4px solid #dc3545 !important;">
                <div class="card-body">
                    <h2 class="text-danger fw-bold display-5 mb-0">@ViewBag.TotalCategories</h2>
                    <p class="text-muted mb-0">Categories</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="bg-light py-5 mb-5 border-top border-bottom">
    <div class="container">
        <h2 class="fw-bold text-center mb-5">How It Works</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100 text-center p-4">
                    <div class="card-body">
                        <div class="bg-primary bg-opacity-10 p-3 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-file-earmark-plus text-primary fs-1"></i>
                        </div>
                        <h4 class="fw-bold">1. Post a Project</h4>
                        <p class="text-muted">Describe what you need done, set your budget, and choose a deadline.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100 text-center p-4">
                    <div class="card-body">
                        <div class="bg-success bg-opacity-10 p-3 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-chat-square-text text-success fs-1"></i>
                        </div>
                        <h4 class="fw-bold">2. Receive Bids</h4>
                        <p class="text-muted">Freelancers will review your project and submit their competitive proposals.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100 text-center p-4">
                    <div class="card-body">
                        <div class="bg-warning bg-opacity-10 p-3 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-award text-warning fs-1"></i>
                        </div>
                        <h4 class="fw-bold">3. Hire the Best</h4>
                        <p class="text-muted">Review profiles, ratings, and award the project to the perfect candidate.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (ViewBag.Categories != null && ((IEnumerable<Category>)ViewBag.Categories).Any())
{
    <div class="container mb-5">
        <h2 class="fw-bold text-center mb-5">Browse by Category</h2>
        <div class="row g-3">
            @foreach (var cat in (IEnumerable<Category>)ViewBag.Categories)
            {
                <div class="col-md-4 col-lg-2 col-6">
                    <a asp-controller="Project" asp-action="Browse" asp-route-categoryId="@cat.Id" class="text-decoration-none">
                        <div class="card border-0 shadow-sm text-center p-3 category-card h-100">
                            <div class="card-body">
                                <i class="bi @cat.IconClass fs-2 text-primary mb-2 d-block"></i>
                                <span class="fw-bold text-dark">@cat.Name</span>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
}

@if (ViewBag.RecentProjects != null && ((IEnumerable<Project>)ViewBag.RecentProjects).Any())
{
    <div class="container mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold m-0">Recent Open Projects</h2>
            <a asp-controller="Project" asp-action="Browse" class="btn btn-outline-primary">
                View All <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>
        <div class="row g-4">
            @foreach (var project in (IEnumerable<Project>)ViewBag.RecentProjects)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 project-card position-relative">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="badge bg-primary">@project.Category?.Name</span>
                                <span class="badge bg-success">Open</span>
                            </div>
                            <h5 class="card-title fw-bold text-truncate" title="@project.Title">@project.Title</h5>
                            <p class="card-text text-muted small flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                @project.Description
                            </p>
                            <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                                <div class="fw-bold text-success fs-5">
                                    $@project.Budget.ToString("N0")
                                </div>
                                <div class="text-muted small">
                                    <i class="bi bi-clock me-1"></i>
                                    @(project.Deadline > DateTime.Now ? (project.Deadline - DateTime.Now).Days + " days left" : "Expired")
                                </div>
                            </div>
                            <a asp-controller="Project" asp-action="Details" asp-route-id="@project.Id" class="btn btn-primary w-100 fw-bold mt-3">View Details</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="container mb-5">
        <div class="alert alert-info text-center py-4">
            <i class="bi bi-info-circle fs-3 d-block mb-2"></i>
            No projects are currently open. Check back soon!
        </div>
    </div>
}

@section Scripts {
    <style>
        .category-card { transition: transform 0.2s ease, box-shadow 0.2s ease; cursor: pointer; }
        .category-card:hover { transform: translateY(-3px); box-shadow: 0 8px 25px rgba(0,0,0,0.12) !important; }
        .project-card { transition: transform 0.2s ease, box-shadow 0.2s ease; }
        .project-card:hover { transform: translateY(-5px); box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15) !important; }
        .hero-section { background: linear-gradient(135deg, #0d6efd 0%, #6610f2 100%); }
        .opacity-90 { opacity: 0.9; }
    </style>
}

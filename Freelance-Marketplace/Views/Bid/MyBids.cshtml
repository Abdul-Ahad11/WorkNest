@model List<FreelanceMarketplace.Models.Bid>
@{
    ViewData["Title"] = "My Bids";
    var pending = Model.Count(b => b.Status == FreelanceMarketplace.Models.BidStatus.Pending);
    var accepted = Model.Count(b => b.Status == FreelanceMarketplace.Models.BidStatus.Accepted);
    var rejected = Model.Count(b => b.Status == FreelanceMarketplace.Models.BidStatus.Rejected);
}

<div class="container mt-4">
    <h2 class="fw-bold mb-4"><i class="bi bi-chat-square-dots me-2"></i>My Bids</h2>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm border-start border-primary border-4">
                <div class="card-body">
                    <h5 class="fw-bold text-primary mb-0">@Model.Count</h5>
                    <p class="text-muted mb-0">Total Bids</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm border-start border-warning border-4">
                <div class="card-body">
                    <h5 class="fw-bold text-warning mb-0">@pending</h5>
                    <p class="text-muted mb-0">Pending</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm border-start border-success border-4">
                <div class="card-body">
                    <h5 class="fw-bold text-success mb-0">@accepted</h5>
                    <p class="text-muted mb-0">Accepted</p>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Project</th>
                                <th>Bid Amount</th>
                                <th>Delivery</th>
                                <th>Submitted</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var bid in Model)
                            {
                                <tr>
                                    <td>
                                        <a asp-controller="Project" asp-action="Details" asp-route-id="@bid.ProjectId" class="fw-bold text-decoration-none">
                                            @bid.Project?.Title
                                        </a>
                                        <br />
                                        <small class="text-muted">@bid.Project?.Category?.Name</small>
                                    </td>
                                    <td class="fw-bold text-success">$@bid.Amount.ToString("N0")</td>
                                    <td>@bid.DeliveryDays days</td>
                                    <td><small>@bid.CreatedAt.ToString("MMM dd, yyyy")</small></td>
                                    <td>
                                        @if (bid.Status == FreelanceMarketplace.Models.BidStatus.Pending)
                                        {
                                            <span class="badge bg-warning text-dark">Pending</span>
                                        }
                                        else if (bid.Status == FreelanceMarketplace.Models.BidStatus.Accepted)
                                        {
                                            <span class="badge bg-success">Accepted</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Rejected</span>
                                        }
                                    </td>
                                    <td>
                                        @if (bid.Status == FreelanceMarketplace.Models.BidStatus.Pending)
                                        {
                                            <form asp-controller="Bid" asp-action="WithdrawBid" method="post" onsubmit="return confirm('Withdraw this bid?');">
                                                <input type="hidden" name="bidId" value="@bid.Id" />
                                                <input type="hidden" name="__RequestVerificationToken" value="@System.Text.Encodings.Web.HtmlEncoder.Default.Encode(System.Security.Claims.ClaimsPrincipal.Current?.Identities.FirstOrDefault()?.FindFirst("__RequestVerificationToken")?.Value ?? "")" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-x-circle me-1"></i>Withdraw
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <a asp-controller="Project" asp-action="Details" asp-route-id="@bid.ProjectId" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-eye me-1"></i>View
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox text-muted" style="font-size: 4rem;"></i>
            <h4 class="fw-bold mt-3 text-muted">No bids yet</h4>
            <p class="text-muted">Start by browsing projects and submitting your proposals.</p>
            <a asp-controller="Project" asp-action="Browse" class="btn btn-primary">
                <i class="bi bi-search me-2"></i>Browse Projects
            </a>
        </div>
    }
</div>
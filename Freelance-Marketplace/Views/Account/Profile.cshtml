@model FreelanceMarketplace.ViewModels.Auth.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h3 class="fw-bold text-primary"><i class="bi bi-person-lines-fill me-2"></i>Edit Profile</h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Profile" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="text-center mb-4">
                            @if (!string.IsNullOrEmpty(Model.CurrentProfilePicture))
                            {
                                <img src="@Model.CurrentProfilePicture" alt="Profile Picture" class="rounded-circle mb-3 border shadow-sm" style="width: 150px; height: 150px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center mx-auto mb-3 border shadow-sm" style="width: 150px; height: 150px;">
                                    <i class="bi bi-person text-secondary" style="font-size: 4rem;"></i>
                                </div>
                            }
                            <div class="mb-3">
                                <label asp-for="ProfilePictureFile" class="form-label fw-bold">Update Picture</label>
                                <input asp-for="ProfilePictureFile" class="form-control form-control-sm w-75 mx-auto" type="file" accept="image/*" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="FullName" class="form-label fw-bold"></label>
                                <input asp-for="FullName" class="form-control" />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>

                            @if (User.IsInRole("Client"))
                            {
                                <div class="col-md-6 mb-3">
                                    <label asp-for="CompanyName" class="form-label fw-bold"></label>
                                    <input asp-for="CompanyName" class="form-control" />
                                    <span asp-validation-for="CompanyName" class="text-danger"></span>
                                </div>
                            }
                        </div>

                        <div class="mb-3">
                            <label asp-for="Bio" class="form-label fw-bold">About Me (Bio)</label>
                            <textarea asp-for="Bio" class="form-control" rows="4" placeholder="Tell clients or freelancers a bit about yourself..."></textarea>
                            <span asp-validation-for="Bio" class="text-danger"></span>
                        </div>

                        @if (User.IsInRole("Freelancer"))
                        {
                            <hr class="my-4" />
                            <h5 class="fw-bold mb-3">Professional Details</h5>

                            <div class="mb-3">
                                <label asp-for="Skills" class="form-label fw-bold"></label>
                                <input asp-for="Skills" class="form-control" />
                                <div class="form-text">Separate skills with commas (e.g., C#, React, SQL)</div>
                                <span asp-validation-for="Skills" class="text-danger"></span>
                            </div>

                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label asp-for="HourlyRate" class="form-label fw-bold"></label>
                                    <div class="input-group">
                                        <span class="input-group-text">$</span>
                                        <input asp-for="HourlyRate" class="form-control" type="number" step="0.01" />
                                    </div>
                                    <span asp-validation-for="HourlyRate" class="text-danger"></span>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="YearsExperience" class="form-label fw-bold"></label>
                                    <input asp-for="YearsExperience" class="form-control" type="number" />
                                    <span asp-validation-for="YearsExperience" class="text-danger"></span>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="PortfolioUrl" class="form-label fw-bold"></label>
                                    <input asp-for="PortfolioUrl" class="form-control" placeholder="https://" />
                                    <span asp-validation-for="PortfolioUrl" class="text-danger"></span>
                                </div>
                            </div>
                        }

                        <div class="mt-4 text-end">
                            <button type="submit" class="btn btn-primary px-4 fw-bold">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
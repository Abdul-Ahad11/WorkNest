@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="display-1 text-danger fw-bold mb-3">500</div>
            <h1 class="text-danger fw-bold mb-3">Something went wrong</h1>
            <p class="text-muted lead mb-4">
                An unexpected error occurred while processing your request.
                Please try again later or contact support if the problem persists.
            </p>

            @if (Model.ShowRequestId)
            {
                <p class="small text-muted">
                    <strong>Request ID:</strong> <code>@Model.RequestId</code>
                </p>
            }

            <div class="mt-4">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg px-5">
                    <i class="bi bi-house-door me-2"></i>Go Home
                </a>
            </div>

            <div class="mt-5 p-4 bg-light rounded">
                <h5 class="text-muted">Need help?</h5>
                <p class="text-muted small mb-0">
                    Contact our support team or try refreshing the page.
                </p>
            </div>
        </div>
    </div>
</div>
@model List<FreelanceMarketplace.Models.Category>
@{
    ViewData["Title"] = "Manage Categories";
    var categoryStats = ViewBag.CategoryStats as List<dynamic> ?? new List<dynamic>();
}

<div class="container mt-4">
    <h2 class="fw-bold mb-4"><i class="bi bi-tags me-2"></i>Manage Categories</h2>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white">
            <h5 class="fw-bold mb-0">Add New Category</h5>
        </div>
        <div class="card-body">
            <form asp-action="CreateCategory" method="post" class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label fw-bold small">Name</label>
                    <input type="text" name="Name" class="form-control" required />
                </div>
                <div class="col-md-5">
                    <label class="form-label fw-bold small">Description</label>
                    <input type="text" name="Description" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold small">Icon Class</label>
                    <input type="text" name="IconClass" class="form-control" value="bi-folder" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold small">&nbsp;</label>
                    <button type="submit" class="btn btn-primary w-100"><i class="bi bi-plus me-1"></i>Add</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Icon</th>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Projects</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var category in Model)
                        {
                            var stat = categoryStats.FirstOrDefault(s => ((Category)s.Category).Id == category.Id);
                            var projectCount = stat != null ? (int)stat.ProjectCount : 0;

                            <tr id="category-row-@category.Id">
                                <td><i class="bi @category.IconClass fs-4 text-primary"></i></td>
                                <td class="fw-bold">
                                    <span id="cat-name-@category.Id">@category.Name</span>
                                </td>
                                <td id="cat-desc-@category.Id">@category.Description</td>
                                <td><span class="badge bg-info">@projectCount projects</span></td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary edit-cat-btn"
                                            data-id="@category.Id"
                                            data-name="@category.Name"
                                            data-desc="@category.Description"
                                            data-icon="@category.IconClass"
                                            data-bs-toggle="modal" data-bs-target="#editCategoryModal">
                                        <i class="bi bi-pencil me-1"></i>Edit
                                    </button>
                                    @if (projectCount == 0)
                                    {
                                        <button class="btn btn-sm btn-outline-danger delete-cat-btn" data-category-id="@category.Id">
                                            <i class="bi bi-trash me-1"></i>Delete
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-secondary" disabled title="Cannot delete category with active projects">
                                            <i class="bi bi-trash me-1"></i>Delete
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                    <p class="text-muted mt-2">No categories found.</p>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="editCategoryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Edit Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="editCategoryForm">
                <div class="modal-body">
                    <input type="hidden" name="Id" id="editCatId" />
                    <div class="mb-3">
                        <label class="form-label fw-bold">Name</label>
                        <input type="text" name="Name" id="editCatName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Description</label>
                        <input type="text" name="Description" id="editCatDesc" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Icon Class</label>
                        <input type="text" name="IconClass" id="editCatIcon" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check me-1"></i>Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.edit-cat-btn').on('click', function () {
                $('#editCatId').val($(this).data('id'));
                $('#editCatName').val($(this).data('name'));
                $('#editCatDesc').val($(this).data('desc'));
                $('#editCatIcon').val($(this).data('icon'));
            });

            $('#editCategoryForm').on('submit', function (e) {
                e.preventDefault();
                var formData = {
                    Id: parseInt($('#editCatId').val()),
                    Name: $('#editCatName').val(),
                    Description: $('#editCatDesc').val(),
                    IconClass: $('#editCatIcon').val()
                };

                $.post('/Admin/EditCategory', formData)
                    .done(function (response) {
                        if (response.success) {
                            var id = formData.Id;
                            $('#cat-name-' + id).text(formData.Name);
                            $('#cat-desc-' + id).text(formData.Description);
                            $('#editCategoryModal').modal('hide');
                        } else {
                            alert(response.message || 'Failed to update category.');
                        }
                    })
                    .fail(function () {
                        alert('An error occurred.');
                    });
            });

            $('.delete-cat-btn').on('click', function () {
                if (!confirm('Delete this category?')) return;
                var catId = $(this).data('category-id');
                var btn = $(this);

                $.post('/Admin/DeleteCategory', { id: catId })
                    .done(function (response) {
                        if (response.success) {
                            $('#category-row-' + catId).fadeOut(300, function () { $(this).remove(); });
                        } else {
                            alert(response.message || 'Failed to delete category.');
                        }
                    })
                    .fail(function () {
                        alert('An error occurred.');
                    });
            });
        });
    </script>
}
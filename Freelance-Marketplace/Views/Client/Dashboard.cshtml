@model IEnumerable<FreelanceMarketplace.Models.Project>
@{
    ViewData["Title"] = "Client Dashboard";
}

<div class="container mt-4">
    <h2 class="fw-bold mb-4">My Projects</h2>

    <div class="table-responsive bg-white p-3 shadow-sm rounded">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Project Title</th>
                    <th>Status</th>
                    <th>Budget</th>
                    <th>Bids Received</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var project in Model)
                {
                    <tr>
                        <td class="fw-bold">@project.Title</td>
                        <td><span class="badge bg-info">@project.Status</span></td>
                        <td>$@project.Budget</td>
                        <td>@project.Bids.Count</td>
                        <td>
                            <a asp-action="Details" asp-controller="Project" asp-route-id="@project.Id" class="btn btn-sm btn-primary">Manage</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>